{
  "nodes": [
    {
      "id": "0",
      "type": "text",
      "text": "Andrej Karpathy：从 Vibe Coding 到 Agentic Engineering",
      "x": 0,
      "y": 900,
      "width": 280,
      "height": 52,
      "color": "6"
    },
    {
      "id": "1",
      "type": "text",
      "text": "软件范式演进",
      "x": 360,
      "y": 108,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "2",
      "type": "text",
      "text": "Software 1.0：人工编写代码",
      "x": 680,
      "y": 0,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "3",
      "type": "text",
      "text": "Software 2.0：通过数据训练神经网络",
      "x": 680,
      "y": 72,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "4",
      "type": "text",
      "text": "Software 3.0：基于提示词与上下文的编程",
      "x": 680,
      "y": 144,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "5",
      "type": "text",
      "text": "神经网络作为主机，CPU 变为协处理器",
      "x": 680,
      "y": 216,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "6",
      "type": "text",
      "text": "编程模式的转变",
      "x": 360,
      "y": 468,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "7",
      "type": "text",
      "text": "Vibe Coding",
      "x": 680,
      "y": 360,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "8",
      "type": "text",
      "text": "通过“感觉”驱动代码生成",
      "x": 960,
      "y": 288,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "9",
      "type": "text",
      "text": "降低开发门槛，提高普适性",
      "x": 960,
      "y": 360,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "10",
      "type": "text",
      "text": "注重快速实验与原型开发",
      "x": 960,
      "y": 432,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "11",
      "type": "text",
      "text": "Agentic Engineering",
      "x": 680,
      "y": 576,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "12",
      "type": "text",
      "text": "维持专业软件的质量与安全性",
      "x": 960,
      "y": 504,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "13",
      "type": "text",
      "text": "智能体协调与工程化规范",
      "x": 960,
      "y": 576,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "14",
      "type": "text",
      "text": "超越 10 倍程序员的生产力提升",
      "x": 960,
      "y": 648,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "15",
      "type": "text",
      "text": "AI 智能的特性",
      "x": 360,
      "y": 900,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "16",
      "type": "text",
      "text": "可验证性 (Verifiability)",
      "x": 680,
      "y": 756,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "17",
      "type": "text",
      "text": "强化学习在可验证领域（数学/代码）更强",
      "x": 960,
      "y": 720,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "18",
      "type": "text",
      "text": "不可验证领域的性能相对滞后",
      "x": 960,
      "y": 792,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "19",
      "type": "text",
      "text": "锯齿状智能 (Jagged Intelligence)",
      "x": 680,
      "y": 900,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "20",
      "type": "text",
      "text": "能修复复杂漏洞却答错简单生活逻辑",
      "x": 960,
      "y": 864,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "21",
      "type": "text",
      "text": "受限于训练数据分布和实验室偏好",
      "x": 960,
      "y": 936,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "22",
      "type": "text",
      "text": "召唤幽灵 (Summoning Ghosts)",
      "x": 680,
      "y": 1044,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "23",
      "type": "text",
      "text": "统计模拟回路而非生物进化智能",
      "x": 960,
      "y": 1008,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "24",
      "type": "text",
      "text": "缺乏内在动机与好奇心",
      "x": 960,
      "y": 1080,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "25",
      "type": "text",
      "text": "人类价值的重塑",
      "x": 360,
      "y": 1368,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "26",
      "type": "text",
      "text": "核心技能",
      "x": 680,
      "y": 1224,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "27",
      "type": "text",
      "text": "审美与品味 (Aesthetics)",
      "x": 960,
      "y": 1152,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "28",
      "type": "text",
      "text": "判断力与决策 (Judgment)",
      "x": 960,
      "y": 1224,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "29",
      "type": "text",
      "text": "制定详细规格与愿景 (Spec & Plan)",
      "x": 960,
      "y": 1296,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "30",
      "type": "text",
      "text": "理解力 (Understanding)",
      "x": 680,
      "y": 1404,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "31",
      "type": "text",
      "text": "可以外包思考，不能外包理解",
      "x": 960,
      "y": 1368,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "32",
      "type": "text",
      "text": "人类作为“导演”引导智能体",
      "x": 960,
      "y": 1440,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "33",
      "type": "text",
      "text": "招聘变革",
      "x": 680,
      "y": 1548,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "34",
      "type": "text",
      "text": "从解题拼图转向大型项目实战考核",
      "x": 960,
      "y": 1512,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "35",
      "type": "text",
      "text": "评估利用 AI 工具构建复杂系统的能力",
      "x": 960,
      "y": 1584,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "36",
      "type": "text",
      "text": "未来愿景",
      "x": 360,
      "y": 1728,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "37",
      "type": "text",
      "text": "Agent Native：为智能体设计的原生基础设施",
      "x": 680,
      "y": 1656,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "38",
      "type": "text",
      "text": "从人读文档转向智能体可执行的“动作指令”",
      "x": 680,
      "y": 1728,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "39",
      "type": "text",
      "text": "人与组织之间的 Agent 对接与协作",
      "x": 680,
      "y": 1800,
      "width": 200,
      "height": 52,
      "color": "4"
    }
