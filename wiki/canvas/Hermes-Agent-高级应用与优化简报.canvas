  "nodes": [
    {
      "id": "0",
      "type": "text",
      "text": "Hermes Agent 高级玩法",
      "x": 0,
      "y": 612,
      "width": 280,
      "height": 52,
      "color": "6"
    },
    {
      "id": "1",
      "type": "text",
      "text": "Ollama 云端免费模型",
      "x": 360,
      "y": 108,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "2",
      "type": "text",
      "text": "特点：内置 Hermes Agent，一键部署",
      "x": 680,
      "y": 0,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "3",
      "type": "text",
      "text": "优势：不占本地资源，傻瓜化配置",
      "x": 680,
      "y": 72,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "4",
      "type": "text",
      "text": "模型示例：Minimax M2.7 云端版",
      "x": 680,
      "y": 144,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "5",
      "type": "text",
      "text": "步骤：官网下载 -> 安装运行 -> 连接设备 -> 刷新 Gateway",
      "x": 680,
      "y": 216,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "6",
      "type": "text",
      "text": "Open WebUI 交互优化",
      "x": 360,
      "y": 540,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "7",
      "type": "text",
      "text": "核心功能",
      "x": 680,
      "y": 396,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "8",
      "type": "text",
      "text": "原生支持：完美解析 Markdown 格式",
      "x": 960,
      "y": 288,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "9",
      "type": "text",
      "text": "历史管理：左侧边栏保存对话记录",
      "x": 960,
      "y": 360,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "10",
      "type": "text",
      "text": "代码增强：支持流式输出、运行 Python 代码",
      "x": 960,
      "y": 432,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "11",
      "type": "text",
      "text": "多模态：上传文件、截图、网页引用",
      "x": 960,
      "y": 504,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "12",
      "type": "text",
      "text": "配置步骤",
      "x": 680,
      "y": 648,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "13",
      "type": "text",
      "text": "修改配置文件：启用 API 服务、设置访问密码",
      "x": 960,
      "y": 576,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "14",
      "type": "text",
      "text": "部署：执行官方安装与启动命令",
      "x": 960,
      "y": 648,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "15",
      "type": "text",
      "text": "Web 设置：添加连接 (URL/端口8642/密码)",
      "x": 960,
      "y": 720,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "16",
      "type": "text",
      "text": "多端访问：支持手机浏览器通过 IP 地址远程连接",
      "x": 680,
      "y": 792,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "17",
      "type": "text",
      "text": "Token 节省配置",
      "x": 360,
      "y": 972,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "18",
      "type": "text",
      "text": "核心策略：主副模型分工 (复杂任务 vs 简单任务)",
      "x": 680,
      "y": 864,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "19",
      "type": "text",
      "text": "副模型 (辅助任务) 配置",
      "x": 680,
      "y": 972,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "20",
      "type": "text",
      "text": "任务类型：批准、压缩、MCP调用、Session 搜索、视觉、网页等",
      "x": 960,
      "y": 936,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "21",
      "type": "text",
      "text": "推荐模型：Gemini 1.5 Flash (性价比高)",
      "x": 960,
      "y": 1008,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "22",
      "type": "text",
      "text": "操作：在配置文件中为不同任务指定 API Key 和模型 ID",
      "x": 680,
      "y": 1080,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "23",
      "type": "text",
      "text": "项目优势",
      "x": 360,
      "y": 1188,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "24",
      "type": "text",
      "text": "稳定性：碾压 OpenCloud，更新少 Bug",
