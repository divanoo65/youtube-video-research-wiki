      "y": 396,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "6",
      "type": "text",
      "text": "Vibe Coding",
      "x": 680,
      "y": 288,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "7",
      "type": "text",
      "text": "提高软件开发门槛下限",
      "x": 960,
      "y": 216,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "8",
      "type": "text",
      "text": "基于直觉与信任的开发",
      "x": 960,
      "y": 288,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "9",
      "type": "text",
      "text": "加速侧边项目产出",
      "x": 960,
      "y": 360,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "10",
      "type": "text",
      "text": "代理工程 (Agentic Engineering)",
      "x": 680,
      "y": 504,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "11",
      "type": "text",
      "text": "维持专业软件质量上限",
      "x": 960,
      "y": 432,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "12",
      "type": "text",
      "text": "协调多个随机性代理",
      "x": 960,
      "y": 504,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "13",
      "type": "text",
      "text": "超越10倍的生产力提升",
      "x": 960,
      "y": 576,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "14",
      "type": "text",
      "text": "AI 智能特性",
      "x": 360,
      "y": 792,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "15",
      "type": "text",
      "text": "可验证性 (Verifiability)",
      "x": 680,
      "y": 684,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "16",
      "type": "text",
      "text": "RL训练在可验证领域表现更强",
      "x": 960,
      "y": 648,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "17",
      "type": "text",
      "text": "数学与代码是典型领域",
      "x": 960,
      "y": 720,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "18",
      "type": "text",
      "text": "锯齿状智能 (Jagged Intelligence)",
      "x": 680,
      "y": 864,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "19",
      "type": "text",
      "text": "复杂任务胜任而简单常识出错",
      "x": 960,
      "y": 792,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "20",
      "type": "text",
      "text": "受限于训练数据分布",
      "x": 960,
      "y": 864,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "21",
      "type": "text",
      "text": "召唤“幽灵”而非进化“动物”",
      "x": 960,
      "y": 936,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
