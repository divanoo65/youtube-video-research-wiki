{
  "nodes": [
    {
      "id": "0",
      "type": "text",
      "text": "安德烈·卡帕斯：从Vibe Coding到代理工程",
      "x": 0,
      "y": 720,
      "width": 280,
      "height": 52,
      "color": "6"
    },
    {
      "id": "1",
      "type": "text",
      "text": "软件范式演进",
      "x": 360,
      "y": 72,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "2",
      "type": "text",
      "text": "软件 1.0：显式规则/编写代码",
      "x": 680,
      "y": 0,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "3",
      "type": "text",
      "text": "软件 2.0：神经网络/学习权重",
      "x": 680,
      "y": 72,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "4",
      "type": "text",
      "text": "软件 3.0：提示词工程/LLM作为计算机",
      "x": 680,
      "y": 144,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "5",
      "type": "text",
