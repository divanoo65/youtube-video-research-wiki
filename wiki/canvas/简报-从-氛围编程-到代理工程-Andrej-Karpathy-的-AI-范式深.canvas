{
  "nodes": [
    {
      "id": "0",
      "type": "text",
      "text": "安德烈·卡帕斯：从Vibe Coding到智能体工程",
      "x": 0,
      "y": 900,
      "width": 280,
      "height": 52,
      "color": "6"
    },
    {
      "id": "1",
      "type": "text",
      "text": "计算范式的演进",
      "x": 360,
      "y": 108,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "2",
      "type": "text",
      "text": "软件1.0：显式规则与代码编写",
      "x": 680,
      "y": 0,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "3",
      "type": "text",
      "text": "软件2.0：通过数据集训练神经网络",
      "x": 680,
      "y": 72,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "4",
      "type": "text",
      "text": "软件3.0：基于提示词与上下文的编程",
      "x": 680,
      "y": 144,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "5",
      "type": "text",
      "text": "未来愿景：神经计算机成为宿主，CPU变为协处理器",
      "x": 680,
      "y": 216,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "6",
      "type": "text",
      "text": "编程模式的变革",
      "x": 360,
      "y": 504,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "7",
      "type": "text",
      "text": "Vibe Coding (氛围编程)",
      "x": 680,
      "y": 360,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "8",
      "type": "text",
      "text": "提高编程门槛的底线",
      "x": 960,
      "y": 288,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "9",
      "type": "text",
      "text": "依靠直觉和语言描述实现功能",
      "x": 960,
      "y": 360,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "10",
      "type": "text",
      "text": "非专业开发者也能构建软件",
      "x": 960,
      "y": 432,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "11",
      "type": "text",
      "text": "Agentic Engineering (智能体工程)",
      "x": 680,
      "y": 612,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "12",
      "type": "text",
      "text": "保持专业软件的质量标准",
      "x": 960,
      "y": 504,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "13",
      "type": "text",
      "text": "协调多个智能体完成任务",
      "x": 960,
      "y": 576,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "14",
      "type": "text",
      "text": "追求超过10倍的效率提升",
      "x": 960,
      "y": 648,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "15",
      "type": "text",
      "text": "关注安全性与工程严谨性",
      "x": 960,
      "y": 720,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "16",
      "type": "text",
      "text": "LLM的核心特性",
      "x": 360,
      "y": 936,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "17",
      "type": "text",
      "text": "可验证性 (Verifiability)",
      "x": 680,
      "y": 828,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "18",
      "type": "text",
      "text": "通过强化学习(RL)在可验证领域(数学/代码)达到高峰",
      "x": 960,
      "y": 792,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "19",
      "type": "text",
      "text": "不可验证领域的表现相对平庸",
      "x": 960,
      "y": 864,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "20",
      "type": "text",
      "text": "锯齿状智能 (Jagged Intelligence)",
      "x": 680,
      "y": 1008,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "21",
      "type": "text",
      "text": "强大能力与基础错误并存(如草莓字母数问题)",
      "x": 960,
      "y": 936,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "22",
      "type": "text",
      "text": "受实验室训练数据和奖励函数影响",
      "x": 960,
      "y": 1008,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "23",
      "type": "text",
      "text": "并非生物智能，更像统计模拟的“幽灵”",
      "x": 960,
      "y": 1080,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "24",
      "type": "text",
      "text": "智能体原生环境 (Agent Native)",
      "x": 360,
      "y": 1260,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "25",
      "type": "text",
      "text": "重构为智能体设计的文档和API",
      "x": 680,
      "y": 1152,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "26",
      "type": "text",
      "text": "减少人类手动操作环节(如配置DNS/部署服务)",
      "x": 680,
      "y": 1224,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "27",
      "type": "text",
      "text": "感知器(Sensors)与执行器(Actuators)的解构",
      "x": 680,
      "y": 1296,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "28",
      "type": "text",
      "text": "智能体间的相互沟通与协作",
      "x": 680,
      "y": 1368,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "29",
      "type": "text",
      "text": "人类价值与教育",
      "x": 360,
      "y": 1620,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "30",
      "type": "text",
      "text": "依然重要的技能",
      "x": 680,
      "y": 1548,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "31",
      "type": "text",
      "text": "审美(Aesthetics)",
      "x": 960,
      "y": 1440,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "32",
      "type": "text",
      "text": "判断力与品味(Judgment and Taste)",
      "x": 960,
      "y": 1512,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "33",
      "type": "text",
      "text": "理解力(Understanding)",
      "x": 960,
      "y": 1584,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "34",
      "type": "text",
      "text": "系统设计与规格说明(Spec)",
      "x": 960,
      "y": 1656,
      "width": 180,
      "height": 52,
      "color": "3"
    },
    {
      "id": "35",
      "type": "text",
      "text": "思维可外包，理解不可外包",
      "x": 680,
      "y": 1728,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "36",
      "type": "text",
      "text": "人类作为“导演”，LLM作为“高效实习生”",
      "x": 680,
      "y": 1800,
      "width": 200,
      "height": 52,
      "color": "4"
    }
  ],
