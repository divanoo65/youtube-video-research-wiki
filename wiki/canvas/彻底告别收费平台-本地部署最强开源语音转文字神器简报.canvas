{
  "nodes": [
    {
      "id": "0",
      "type": "text",
      "text": "本地部署最强语音转文字神器教程",
      "x": 0,
      "y": 1080,
      "width": 280,
      "height": 52,
      "color": "6"
    },
    {
      "id": "1",
      "type": "text",
      "text": "核心优势",
      "x": 360,
      "y": 108,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "2",
      "type": "text",
      "text": "高效性能：33小时录音12分钟转完",
      "x": 680,
      "y": 0,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "3",
      "type": "text",
      "text": "多语种支持：中英日等十几种语言",
      "x": 680,
      "y": 72,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "4",
      "type": "text",
      "text": "完全本地运行：保护隐私，免费使用",
